{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credential-intelligence-platform.local/schemas/credential_v1.schema.json",
  "title": "credential_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "credential_id",
    "type",
    "issuer_id",
    "subject_id",
    "title",
    "source_type",
    "created_at",
    "status",
    "credential_subject"
  ],
  "properties": {
    "schema_version": {
      "const": "credential_v1"
    },
    "credential_id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "academic_subject",
        "course",
        "certification",
        "degree"
      ]
    },
    "issuer_id": {
      "type": "string",
      "minLength": 1
    },
    "issuer_did": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_did": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "academic_pdf",
        "course_dataset",
        "manual_issuer",
        "institutional_system",
        "external_import"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "revoked"
      ]
    },
    "canonical_hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "canonicalization_version": {
      "type": "string",
      "minLength": 1
    },
    "hours": {
      "type": "number",
      "minimum": 0
    },
    "revoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "revocation_reason": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "language": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "origin_system": {
          "type": "string"
        }
      }
    },
    "credential_subject": {
      "$ref": "#/$defs/credentialSubject"
    },
    "raw_data": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "credentialSubject": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "achievement_name",
        "institution_name"
      ],
      "properties": {
        "achievement_name": {
          "type": "string",
          "minLength": 1
        },
        "institution_name": {
          "type": "string",
          "minLength": 1
        },
        "academic_period": {
          "type": "string"
        },
        "completion_date": {
          "type": "string",
          "format": "date"
        },
        "grade": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            }
          ]
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "competencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceItem"
          }
        }
      }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
