{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credential-intelligence-platform.local/schemas/blockchain_record_v1.schema.json",
  "title": "blockchain_record_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "credential_id",
    "credential_hash",
    "network",
    "contract_address",
    "tx_hash",
    "issuer_address",
    "registered_at",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "blockchain_record_v1"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "credential_id": {
      "type": "string",
      "minLength": 1
    },
    "credential_hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "network": {
      "type": "string",
      "enum": [
        "anvil",
        "base-sepolia",
        "base-mainnet"
      ]
    },
    "contract_address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "tx_hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "issuer_address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "registered_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "registered",
        "revoked"
      ]
    }
  }
}
