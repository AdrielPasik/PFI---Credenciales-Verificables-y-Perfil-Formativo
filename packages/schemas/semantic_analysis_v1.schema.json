{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credential-intelligence-platform.local/schemas/semantic_analysis_v1.schema.json",
  "title": "semantic_analysis_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "analysis_id",
    "credential_id",
    "status",
    "pipeline_version",
    "taxonomy_version",
    "analyzed_at",
    "areas",
    "skills",
    "concepts",
    "quality_flags",
    "evidence_map",
    "text_for_embedding",
    "confidence"
  ],
  "properties": {
    "schema_version": {
      "const": "semantic_analysis_v1"
    },
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "credential_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial"
      ]
    },
    "pipeline_version": {
      "type": "string",
      "minLength": 1
    },
    "taxonomy_version": {
      "type": "string",
      "minLength": 1
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time"
    },
    "areas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/areaResult"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillResult"
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conceptResult"
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_map": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "text_for_embedding": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "areaResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "score",
        "evidence"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "skillResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source",
        "confidence",
        "evidence"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "conceptResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "relevance",
        "evidence"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
