{
  "name": "@credential-intelligence/api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal NestJS backend scaffold with Prisma tooling.",
  "scripts": {
    "dev": "node --watch --require ts-node/register --require reflect-metadata src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "node --env-file=.env -r ts-node/register/transpile-only prisma/seed.ts",
    "blockchain:register": "node --env-file=.env -r ts-node/register/transpile-only -r reflect-metadata src/blockchain/scripts/register-credential-on-registry.ts",
    "blockchain:revoke": "node --env-file=.env -r ts-node/register/transpile-only -r reflect-metadata src/blockchain/scripts/revoke-credential-on-registry.ts",
    "blockchain:status": "node --env-file=.env -r ts-node/register/transpile-only -r reflect-metadata src/blockchain/scripts/check-credential-registry-status.ts",
    "semantic:ingest:file": "node --env-file=.env -r ts-node/register/transpile-only -r reflect-metadata src/semantic/scripts/ingest-semantic-analysis-file.ts",
    "test:blockchain-evidence": "node --require ts-node/register/transpile-only --test src/blockchain/blockchain-evidence.service.test.ts",
    "test:blockchain-read-client": "node --require ts-node/register/transpile-only --test src/blockchain/credential-registry-read-client.test.ts",
    "test:blockchain-write-client": "node --require ts-node/register/transpile-only --test src/blockchain/credential-registry-write-client.test.ts",
    "test:auth": "node --require ts-node/register/transpile-only --test src/auth/password-hashing.test.ts src/auth/auth.service.test.ts src/auth/auth.guard.test.ts src/auth/auth.controller.test.ts",
    "test:protected-issuance": "node --require ts-node/register/transpile-only --test src/credentials/credentials.controller.test.ts src/credentials/credentials.service.test.ts",
    "test:hashing": "node --require ts-node/register/transpile-only --test src/credentials/credential-hashing.service.test.ts",
    "test:semantic-artifact": "node --require ts-node/register/transpile-only --test src/semantic/semantic-analysis-artifact.mapper.test.ts",
    "test:semantic-service": "node --require ts-node/register/transpile-only --test src/semantic/semantic.service.test.ts",
    "test:semantic-cli": "node --require ts-node/register/transpile-only --test src/semantic/scripts/ingest-semantic-analysis-file.test.ts",
    "test:semantic-read": "node --require ts-node/register/transpile-only --test src/semantic/semantic.controller.test.ts",
    "test:verification-read": "node --require ts-node/register/transpile-only --test src/verification/verification.service.test.ts src/verification/verification.controller.test.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/client": "6.19.3",
    "ethers": "6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prisma": "6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
