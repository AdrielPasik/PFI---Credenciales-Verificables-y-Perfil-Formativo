{
  "name": "@credential-intelligence/api",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal NestJS backend scaffold with Prisma tooling.",
  "scripts": {
    "dev": "node --watch --require ts-node/register --require reflect-metadata src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "node --env-file=.env -r ts-node/register/transpile-only prisma/seed.ts",
    "semantic:ingest:file": "node --env-file=.env -r ts-node/register/transpile-only -r reflect-metadata src/semantic/scripts/ingest-semantic-analysis-file.ts",
    "test:hashing": "node --require ts-node/register/transpile-only --test src/credentials/credential-hashing.service.test.ts",
    "test:semantic-artifact": "node --require ts-node/register/transpile-only --test src/semantic/semantic-analysis-artifact.mapper.test.ts",
    "test:semantic-service": "node --require ts-node/register/transpile-only --test src/semantic/semantic.service.test.ts",
    "test:semantic-cli": "node --require ts-node/register/transpile-only --test src/semantic/scripts/ingest-semantic-analysis-file.test.ts",
    "test:semantic-read": "node --require ts-node/register/transpile-only --test src/semantic/semantic.controller.test.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/client": "6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prisma": "6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
