{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://credential-intelligence-platform.local/schemas/semantic_analysis_v1.schema.json",
  "title": "semantic_analysis_v1",
  "description": "Artifact semantico versionado producido por el modulo IA y asociado a una Credential por contexto externo del backend.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "pipelineVersion",
    "taxonomyVersion",
    "status",
    "sourceType",
    "sourceRefs",
    "areas",
    "skills",
    "concepts",
    "hoursDistribution",
    "evidenceMap",
    "confidence",
    "qualityFlags",
    "warnings",
    "partialReasons",
    "textForEmbedding"
  ],
  "properties": {
    "schemaVersion": {
      "const": "semantic_analysis_v1"
    },
    "pipelineVersion": {
      "type": "string",
      "minLength": 1
    },
    "taxonomyVersion": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "partial"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "academic_pdf",
        "online_course_catalog"
      ]
    },
    "sourceRefs": {
      "$ref": "#/$defs/sourceRefs"
    },
    "areas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/areaEntry"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillEntry"
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conceptEntry"
      }
    },
    "hoursDistribution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hoursDistributionEntry"
      }
    },
    "evidenceMap": {
      "$ref": "#/$defs/evidenceMap"
    },
    "confidence": {
      "$ref": "#/$defs/confidenceSummary"
    },
    "qualityFlags": {
      "$ref": "#/$defs/stringArray"
    },
    "warnings": {
      "$ref": "#/$defs/stringArray"
    },
    "partialReasons": {
      "$ref": "#/$defs/stringArray"
    },
    "textForEmbedding": {
      "type": "string"
    }
  },
  "$defs": {
    "confidenceMethod": {
      "type": "string",
      "enum": [
        "measured",
        "derived",
        "heuristic",
        "unavailable"
      ]
    },
    "nullableConfidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sourceRefs": {
      "type": "object",
      "required": [
        "documentId"
      ],
      "properties": {
        "documentId": {
          "type": "string",
          "minLength": 1
        },
        "fileName": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "areaEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "confidence",
        "confidenceMethod",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "confidenceMethod": {
          "$ref": "#/$defs/confidenceMethod"
        },
        "source": {
          "type": "string",
          "enum": [
            "explicit",
            "inferred"
          ]
        }
      }
    },
    "skillEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "confidence",
        "confidenceMethod",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "confidenceMethod": {
          "$ref": "#/$defs/confidenceMethod"
        },
        "source": {
          "type": "string",
          "enum": [
            "explicit",
            "inferred"
          ]
        }
      }
    },
    "conceptEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "confidence",
        "confidenceMethod"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "confidenceMethod": {
          "$ref": "#/$defs/confidenceMethod"
        }
      }
    },
    "hoursDistributionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "areaId",
        "hours"
      ],
      "properties": {
        "areaId": {
          "type": "string",
          "minLength": 1
        },
        "hours": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "evidenceMapSection": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/stringArray"
      }
    },
    "evidenceMap": {
      "type": "object",
      "required": [
        "areas",
        "skills",
        "concepts"
      ],
      "properties": {
        "areas": {
          "$ref": "#/$defs/evidenceMapSection"
        },
        "skills": {
          "$ref": "#/$defs/evidenceMapSection"
        },
        "concepts": {
          "$ref": "#/$defs/evidenceMapSection"
        }
      },
      "additionalProperties": true
    },
    "confidenceSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "global",
        "globalMethod",
        "coverage",
        "coverageMethod"
      ],
      "properties": {
        "global": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "globalMethod": {
          "$ref": "#/$defs/confidenceMethod"
        },
        "coverage": {
          "$ref": "#/$defs/nullableConfidence"
        },
        "coverageMethod": {
          "$ref": "#/$defs/confidenceMethod"
        }
      }
    }
  }
}
